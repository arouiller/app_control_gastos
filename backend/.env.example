# Servidor
PORT=5000
NODE_ENV=development

# Versión de base de datos esperada (debe coincidir con la última en database/migrations/versions.json)
APP_VERSION=1.0.2

# Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=control_gastos
DB_USER=root
DB_PASSWORD=tu_password

# JWT
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=tu_refresh_secret_muy_seguro_aqui
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Email (para recuperación de contraseña - futuro)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@email.com
# SMTP_PASSWORD=tu_password_email
