# Servidor
PORT=5000
NODE_ENV=development

# Versión de base de datos esperada (debe coincidir con la última en database/migrations/versions.json)
APP_VERSION=1.0.2

# Base de Datos - CAMBIAR ESTAS CREDENCIALES
DB_HOST=localhost
DB_PORT=3306
DB_NAME=control_gastos
DB_USER=root
DB_PASSWORD=

# JWT - CAMBIAR ESTOS SECRETS EN PRODUCCIÓN
JWT_SECRET=control_gastos_jwt_secret_dev_2026
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=control_gastos_refresh_secret_dev_2026
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
